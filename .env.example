# ============================================================================
# FluenSys — environment variables
# ----------------------------------------------------------------------------
# Copy to .env.local for local development. On Vercel, add these under
# Project → Settings → Environment Variables (Production + Preview).
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser by design.
# ============================================================================

# ----------------------------------------------------------------------------
# Site
# ----------------------------------------------------------------------------
# Canonical origin used for SEO metadata, sitemap, RSS and JSON-LD.
# Production: https://www.fluensys.co.uk   Preview: your *.vercel.app URL.
NEXT_PUBLIC_SITE_URL=https://www.fluensys.co.uk

# ----------------------------------------------------------------------------
# Firebase (Auth: anonymous guest + Google sign-in · Firestore: bookmarks,
# comments, newsletter subscribers)
# ----------------------------------------------------------------------------
# Firebase Console → Project settings → General → Your apps → Web app config.
# These are public client identifiers (not secrets); access control is
# enforced by firestore.rules. The app degrades gracefully if unset —
# auth/bookmarks/comments/newsletter UI simply hides itself.
#
# Setup checklist (Firebase Console):
#   1. Authentication → Sign-in method → enable "Google" and "Anonymous".
#   2. Authentication → Settings → Authorized domains → add fluensys.co.uk
#      and your *.vercel.app preview domain.
#   3. Firestore → create database (production mode, eur3/europe-west2).
#   4. Rules & indexes deploy automatically from main (firestore-deploy
#      workflow + FIREBASE_SERVICE_ACCOUNT_KEY repo secret — see the
#      GitHub section at the bottom). Manual fallback from any clone:
#      npm i -g firebase-tools && firebase login && firebase deploy --only firestore
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — only if you enable Google Analytics for Firebase.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ----------------------------------------------------------------------------
# Analytics (optional)
# ----------------------------------------------------------------------------
# Google Tag Manager container id (the v1 site used GTM-N54TK3V6).
# Leave empty to ship no third-party analytics.
NEXT_PUBLIC_GTM_ID=

# ----------------------------------------------------------------------------
# Newsletter sending (optional, server-side — Phase 2)
# ----------------------------------------------------------------------------
# Subscriber capture is Firestore-native and needs no key. When automated
# digest sending is enabled (docs/08-roadmap.md), provision Resend and set:
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=journal@fluensys.co.uk

# ----------------------------------------------------------------------------
# Server-side Firebase Admin
# ----------------------------------------------------------------------------
# The same single-line service-account JSON lives in TWO places:
#   - Vercel env var (this one): reserved for Phase-2 server features
#     (newsletter digest sending, comment moderation API) — optional today.
#   - GitHub Actions repo secret of the same name: REQUIRED for the
#     firestore-deploy workflow (auto-deploys rules/indexes from main).
# Formatting: paste the full JSON on a single line, keeping the literal \n
# escapes inside "private_key" exactly as downloaded (they become real
# newlines when the JSON is parsed). Minify + copy with:
#   node -e "console.log(JSON.stringify(require('./<key-file>.json')))"
# Firebase Console → Project settings → Service accounts → Generate key.
# The account needs the Firebase Admin role (roles/firebase.admin) in IAM
# for CI deploys.
FIREBASE_SERVICE_ACCOUNT_KEY=

# ============================================================================
# GitHub Actions secrets (NOT Vercel variables)
# ----------------------------------------------------------------------------
# Where exactly: repo → Settings → Secrets and variables → Actions →
# "Secrets" tab → "Repository secrets" → New repository secret.
#
# That page has four buckets — for this repo, ONLY "Repository secrets"
# is used:
#   - Repository secrets  ✔ all three entries below go here
#   - Environment secrets ✘ only visible to jobs declaring a GitHub
#       deployment `environment:` — our workflows don't use environments
#   - Repository/Environment variables ✘ plaintext config exposed via
#       ${{ vars.* }} (visible in UI/logs) — currently unused here
#
#   CLAUDE_ROUTINE_FIRE_URL       API-trigger URL of the "FluenSys:
#                                 Commission Article" Claude Code routine
#                                 (used by commission-dispatch.yml)
#   CLAUDE_ROUTINE_TOKEN          that routine's bearer token — shown once
#                                 when generated in the Claude app
#                                 (used by commission-dispatch.yml)
#   FIREBASE_SERVICE_ACCOUNT_KEY  same single-line service-account JSON as
#                                 the Vercel variable above (used by
#                                 firestore-deploy.yml to auto-deploy
#                                 rules/indexes from main)
#
# No model API keys are needed anywhere: authoring runs as Claude Code
# Routines (claude.ai/code/routines) on the operator's claude.ai
# subscription. Setup: docs/03-routines.md → "Create the routines".
# ============================================================================
